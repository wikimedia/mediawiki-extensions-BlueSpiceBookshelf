{
	"root": true,
	"extends": [
		"wikimedia/client",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"parserOptions": {
		"sourceType": "commonjs"
	},
	"globals": {
		"blueSpice": "readonly",
		"bs": "readonly",
		"ext": "readonly",
		"jQuery": "readonly",
		"mediaWiki": "readonly",
		"OOJSPlus": "readonly",
		"QUnit": "readonly",
		"ve": "readonly"
	},
	"rules": {
		"max-len": "off",
		"mediawiki/no-unlabeled-buttonwidget": "off",
		"no-jquery/variable-pattern": "off",
		"no-prototype-builtins": "off",
		"no-jquery/no-done-fail": "warn"
	}
}
